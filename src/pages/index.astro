---
import { cx } from 'class-variance-authority'

import Layout from '@/components/Layout/Layout.astro'
import ProjectCardWork from '@/components/ProjectCardWork.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import { pinnedProjects } from '@/data'

const projects = pinnedProjects
---

<Layout sideBarActiveItemID="home">
  <div class="mt-5 pb-12">
    <div class="text-5xl font-bold">Isto Nikula</div>
    <div class="mt-3">
      <SectionHeading>Freelance Full Stack Developer</SectionHeading>
    </div>
    <div class="prose-sm mt-5">
      <p>
        I specialize in designing robust software systems and efficiently coordinating the artificial intelligences that
        help build them.
      </p>
      <p>
        Unlike the models I orchestrate, my context has been permanently loaded with years of practical, hands-on
        experience in full-stack development and functional programming. Today, my day-to-day involves herding agentic
        AI workflows to turn complex business requirements into reality faster than ever.
      </p>
      <p>
        I bring the critical Organic Intelligence required for high-level strategy, system architecture, and long-term
        maintainability—while leveraging GenAI to accelerate the rest.
      </p>
    </div>
  </div>

  <div class="mb-2">
    <SectionHeading>Latest Projects</SectionHeading>
  </div>

  {
    projects.map((p, idx) => (
      <>
        <div class={cx('divider my-0', { hidden: idx === 0 })} />
        <ProjectCardWork slug={p.slug} project={p} />
      </>
    ))
  }
</Layout>
