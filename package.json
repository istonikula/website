    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@types/lodash-es": "4.17.12",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "astro": "6.1.3",
    "astro-icon": "1.1.5",
    "class-variance-authority": "0.7.1",
    "daisyui": "5.5.19",
